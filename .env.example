# ─── Project to audit ────────────────────────────────────────────────────────
# Absolute path to the root of the project you want to audit
# The tool will look for the backend at PROJECT_ROOT/backend/src/
PROJECT_ROOT=/path/to/project

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=7777

# ─── AI Providers (optional) ──────────────────────────────────────────────────
# If set, Deep Audit and Full Pentest modes will send real code snippets to
# the selected provider for deeper analysis. Standard mode works without AI.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
